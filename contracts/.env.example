# VAPI Contract Deployment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# --- Deployer Wallet ---
# Key source: "env" (testnet/dev, plaintext) or "keystore" (mainnet, encrypted JSON).
# Production MUST use "keystore" — never store a mainnet private key in plaintext.
DEPLOYER_KEY_SOURCE=env

# Plaintext private key (required when DEPLOYER_KEY_SOURCE=env).
# Fund this wallet with testnet IOTX from: https://faucet.iotex.io/
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- Deployer Keystore (production mainnet only) ---
# Required when DEPLOYER_KEY_SOURCE=keystore.
# Generate with: node -e "const {ethers}=require('ethers'); const w=ethers.Wallet.createRandom(); console.log(JSON.stringify(w.encryptSync('YOUR_PASSWORD')))" > deployer-keystore.json
# Store keystore file in a secure location (not in the repo).
DEPLOYER_KEYSTORE_PATH=/secure/path/deployer-keystore.json
# Name of the env var that holds the keystore decryption password.
DEPLOYER_KEYSTORE_PASSWORD_ENV=DEPLOYER_KEYSTORE_PASSWORD
# (Set DEPLOYER_KEYSTORE_PASSWORD in your secrets manager / CI secrets, not here)

# Minimum deposit for device registration (in wei)
# Default: 1 IOTX = 1000000000000000000
MINIMUM_DEPOSIT=1000000000000000000

# Maximum timestamp skew for PoAC verification (in seconds)
# Default: 3600 (1 hour) — generous for NB-IoT latency
MAX_TIMESTAMP_SKEW=3600

# Platform fee basis points for BountyMarket (100 = 1%)
# Default: 250 (2.5%)
PLATFORM_FEE_BPS=250
